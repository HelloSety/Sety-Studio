[
  {
    "name": "theme_info",
    "theme_name": "Natalia Silveira",
    "theme_version": "1.0.0",
    "theme_author": "Sety Studio",
    "theme_documentation_url": "",
    "theme_support_url": ""
  },
  {
    "name": "Marca",
    "settings": [
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Favicon"
      },
      {
        "type": "text",
        "id": "wpp_number",
        "label": "Número WhatsApp (apenas dígitos, com DDI)",
        "placeholder": "5511999999999",
        "info": "Exemplo: 5541999999999 para Maringá-PR"
      },
      {
        "type": "text",
        "id": "instagram",
        "label": "Instagram (sem @)",
        "placeholder": "nataliasilveira"
      }
    ]
  },
  {
    "name": "Cores",
    "settings": [
      {
        "type": "color",
        "id": "color_text",
        "label": "Cor do texto principal",
        "default": "#111111"
      },
      {
        "type": "color",
        "id": "color_accent",
        "label": "Cor de destaque (warm)",
        "default": "#C4946A"
      }
    ]
  },
  {
    "name": "Checkout / Pedido",
    "settings": [
      {
        "type": "checkbox",
        "id": "prefer_wpp",
        "label": "Destacar botão WhatsApp acima do carrinho",
        "default": true,
        "info": "Recomendado para negócios feitos por WhatsApp"
      },
      {
        "type": "textarea",
        "id": "wpp_message_template",
        "label": "Mensagem padrão WhatsApp",
        "default": "Olá! Quero encomendar uma peça Natalia Silveira.",
        "info": "Mensagem inicial quando o cliente clica no ícone flutuante"
      }
    ]
  }
]
