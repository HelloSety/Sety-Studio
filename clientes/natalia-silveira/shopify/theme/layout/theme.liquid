<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}" data-wpp="{{ settings.wpp_number }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="theme-color" content="#FFFFFF">

  <title>
    {%- if template == 'index' -%}
      {{ shop.name }} — Arte em Macramê do Brasil
    {%- else -%}
      {{ page_title }} — {{ shop.name }}
    {%- endif -%}
  </title>

  {%- if page_description -%}
    <meta name="description" content="{{ page_description | escape }}">
  {%- endif -%}

  {{ content_for_header }}

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,200;0,300;0,400;0,500;1,200;1,300;1,400&family=Jost:wght@300;400;500&display=swap" rel="stylesheet">

  {{ 'theme.css' | asset_url | stylesheet_tag }}

  {%- if settings.favicon -%}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32 }}">
  {%- endif -%}
</head>

<body class="template-{{ template.name }}">

  {%- section 'header' -%}

  <main id="MainContent" role="main">
    {{ content_for_layout }}
  </main>

  {%- section 'footer' -%}

  <!-- Floating Language Selector -->
  {%- assign flag_br = 'flag-br.svg' | asset_url -%}
  {%- assign flag_us = 'flag-us.svg' | asset_url -%}
  {%- assign flag_es = 'flag-es.svg' | asset_url -%}
  <div class="lang-float" id="langFloat"
    data-flag-pt="{{ flag_br }}"
    data-flag-en="{{ flag_us }}"
    data-flag-es="{{ flag_es }}">
    <div class="lang-float-menu" id="langFloatMenu">
      <a href="#" data-sl="pt" class="active">
        <img src="{{ flag_br }}" width="22" height="15" alt="BR" class="lf-flag-img"> Português
      </a>
      <a href="#" data-sl="en">
        <img src="{{ flag_us }}" width="22" height="15" alt="US" class="lf-flag-img"> English
      </a>
      <a href="#" data-sl="es">
        <img src="{{ flag_es }}" width="22" height="15" alt="ES" class="lf-flag-img"> Español
      </a>
    </div>
    <button class="lang-float-btn" id="langFloatBtn" aria-label="Idioma / Language">
      <img src="{{ flag_br }}" width="22" height="15" alt="BR" id="langFloatFlagImg" class="lf-flag-img">
      <span class="lang-float-code" id="langFloatCode">PT</span>
      <span class="lang-float-arrow">›</span>
    </button>
  </div>

  <!-- Floating WhatsApp -->
  <a href="https://wa.me/{{ settings.wpp_number }}" target="_blank" class="wpp-float" aria-label="WhatsApp">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="white"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
  </a>

  <script src="{{ 'theme.js' | asset_url }}" defer></script>
</body>
</html>
