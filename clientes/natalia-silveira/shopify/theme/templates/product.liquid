{%- assign is_consult = false -%}
{%- if product.tags contains 'consultar-preco' -%}
  {%- assign is_consult = true -%}
{%- endif -%}

<!-- Breadcrumb -->
<div class="breadcrumb">
  <a href="/" data-i18n="nav_home">Casa</a>
  <span>›</span>
  <a href="/collections/all" data-i18n="nav_shop">Comprar</a>
  <span>›</span>
  <span>{{ product.title }}</span>
</div>

<div class="product-wrapper">
  <!-- ── GALLERY ── -->
  <div class="product-gallery">
    <div class="gallery-main">
      <img
        id="galleryMain"
        src="{{ product.featured_image | image_url: width: 900 }}"
        alt="{{ product.featured_image.alt | default: product.title }}">
    </div>
    <div class="gallery-thumbs">
      {%- for image in product.images -%}
        <div
          class="gallery-thumb{% if forloop.first %} active{% endif %}"
          data-src="{{ image | image_url: width: 900 }}">
          <img
            src="{{ image | image_url: width: 120 }}"
            alt="{{ image.alt | default: product.title }}"
            loading="lazy">
        </div>
      {%- endfor -%}
    </div>
  </div>

  <!-- ── INFO ── -->
  <div class="product-info">
    <h1 class="product-title">{{ product.title }}</h1>
    <p class="product-type">{{ product.type }}</p>

    {%- if is_consult -%}
      <p class="product-price consult">Sob consulta</p>
    {%- else -%}
      <p class="product-price">{{ product.price | money }}</p>
    {%- endif -%}

    <p class="product-weight" data-i18n="weight">Peso: 1,5 kg</p>

    <hr class="product-divider">

    {%- form 'product', product, id: 'productForm' -%}
      <input type="hidden" name="id" id="variantId" value="{{ product.selected_or_first_available_variant.id }}">

      <!-- SIZE -->
      <p class="option-label" data-i18n="sz_label">TAMANHO</p>
      <div class="size-buttons">
        {%- for variant in product.variants -%}
          <button
            type="button"
            class="size-btn{% if variant == product.selected_or_first_available_variant %} active{% endif %}{% unless variant.available %} unavailable{% endunless %}"
            data-sz="{{ variant.option1 }}"
            data-variant-id="{{ variant.id }}">
            {{ variant.option1 }}
          </button>
        {%- endfor -%}
      </div>

      <!-- COLOR -->
      <p class="option-label">
        <span data-i18n="cl_label">LINHA DE COR</span>
        — <span id="colorSelected" data-i18n="cl_select">Selecione uma cor</span>
      </p>
      <div class="color-tabs">
        <button class="color-tab active" data-cp="premium" data-i18n="cl_premium">PREMIUM</button>
        <button class="color-tab" data-cp="gold" data-i18n="cl_gold">LUREX DOURADO</button>
        <button class="color-tab" data-cp="copper" data-i18n="cl_copper">LUREX COBRE</button>
      </div>
      <div class="color-panel active" id="cp-premium"></div>
      <div class="color-panel" id="cp-gold"></div>
      <div class="color-panel" id="cp-copper"></div>

      <input type="hidden" name="properties[Cor]" id="selectedColorInput" value="">
      <input type="hidden" name="properties[Linha de Cor]" id="selectedLineInput" value="">

      <hr class="product-divider">

      <!-- QUANTITY -->
      <p class="option-label" data-i18n="qty_label">QUANTIDADE</p>
      <div class="qty-wrap">
        <button type="button" class="qty-btn" id="qtyMinus">−</button>
        <input type="number" class="qty-num" id="qtyNum" name="quantity" value="1" min="1" max="10" readonly>
        <button type="button" class="qty-btn" id="qtyPlus">+</button>
      </div>

      <!-- CTA -->
      <button type="submit" class="btn-add-cart" data-i18n="btn_cart">ADICIONAR AO CARRINHO</button>
    {%- endform -%}

    <a id="btnWpp" href="https://wa.me/{{ settings.wpp_number }}" target="_blank" class="btn-wpp" data-i18n="btn_wpp">
      COMPRAR PELO WHATSAPP
    </a>

    <!-- Feito Sob Encomenda -->
    <div class="bespoke-box">
      <p class="bespoke-title" data-i18n="fse_title">FEITO SOB ENCOMENDA</p>
      <p class="bespoke-body" data-i18n="fse_body">Cada peça é produzida exclusivamente sob medida. Prazo: até 20 dias corridos além do envio.</p>
    </div>

    <!-- Accordion -->
    <div class="accordion-item">
      <button class="accordion-trigger" aria-expanded="false">
        <span data-i18n="acc_details">DETALHES DA PEÇA</span>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="m6 9 6 6 6-6"/></svg>
      </button>
      <div class="accordion-body">
        <p>{{ product.description }}</p>
      </div>
    </div>
    <div class="accordion-item">
      <button class="accordion-trigger" aria-expanded="false">
        <span data-i18n="acc_ship">ENVIO E PRAZO</span>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="m6 9 6 6 6-6"/></svg>
      </button>
      <div class="accordion-body">
        <p>Enviamos para todo o Brasil e exterior. Frete calculado pelo endereço de destino. Origem: Maringá — Paraná, Brasil. Peso: 1,5 kg por peça.</p>
      </div>
    </div>
    <div class="accordion-item">
      <button class="accordion-trigger" aria-expanded="false">
        <span data-i18n="acc_care">CUIDADOS COM A PEÇA</span>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="m6 9 6 6 6-6"/></svg>
      </button>
      <div class="accordion-body">
        <p>Lavar à mão com água fria e sabão neutro. Não torcer. Secar à sombra, esticada. Guardar em local seco e arejado. Evitar exposição prolongada ao sol.</p>
      </div>
    </div>
    <div class="accordion-item">
      <button class="accordion-trigger" aria-expanded="false">
        <span data-i18n="acc_return">TROCAS E DEVOLUÇÕES</span>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="m6 9 6 6 6-6"/></svg>
      </button>
      <div class="accordion-body">
        <p>Cada peça é feita exclusivamente sob medida. Não aceitamos trocas por arrependimento, escolha de cor ou modelo. Aceitamos análise em caso de defeito de fabricação (até 7 dias do recebimento).</p>
      </div>
    </div>
  </div>
</div>

<!-- Recommendations -->
<section class="recs-section">
  <h2 class="recs-title" data-i18n="recs_title">VOCÊ TAMBÉM VAI AMAR</h2>
  <div class="recs-grid">
    {%- assign recs_collection = collections.all -%}
    {%- assign rec_count = 0 -%}
    {%- for rec in recs_collection.products -%}
      {%- if rec.id != product.id and rec_count < 5 -%}
        {%- assign rec_is_consult = false -%}
        {%- if rec.tags contains 'consultar-preco' %}{%- assign rec_is_consult = true -%}{%- endif -%}
        <div class="rec-card" onclick="window.location='{{ rec.url }}'">
          <div class="rec-card-image">
            <img src="{{ rec.featured_image | image_url: width: 400 }}" alt="{{ rec.title }}" loading="lazy">
          </div>
          <p class="rec-card-name">{{ rec.title }}</p>
          {%- if rec_is_consult -%}
            <p class="rec-card-price consult">Sob consulta</p>
          {%- else -%}
            <p class="rec-card-price">{{ rec.price | money }}</p>
          {%- endif -%}
        </div>
        {%- assign rec_count = rec_count | plus: 1 -%}
      {%- endif -%}
    {%- endfor -%}
  </div>
</section>

<script>
  // Sync color selection to hidden form fields
  document.querySelectorAll('.color-swatch').forEach(sw => {
    sw.addEventListener('click', () => {
      document.getElementById('selectedColorInput').value = sw.title;
      document.getElementById('selectedLineInput').value = sw.dataset.line || '';
    });
  });
</script>
