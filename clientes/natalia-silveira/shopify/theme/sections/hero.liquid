<section class="hero">
  <div class="hero-image">
    {%- if section.settings.image -%}
      <img
        src="{{ section.settings.image | image_url: width: 1800 }}"
        srcset="{{ section.settings.image | image_url: width: 900 }} 900w, {{ section.settings.image | image_url: width: 1400 }} 1400w, {{ section.settings.image | image_url: width: 1800 }} 1800w"
        sizes="100vw"
        alt="{{ section.settings.image.alt | default: shop.name }}"
        width="1800"
        height="1100"
        loading="eager"
        fetchpriority="high">
    {%- else -%}
      <div class="hero-placeholder"></div>
    {%- endif -%}
  </div>

  <div class="hero-content">
    <div class="hero-inner">
      {%- if section.settings.hero_eyebrow != blank -%}
        <p class="hero-eyebrow">{{ section.settings.hero_eyebrow }}</p>
      {%- endif -%}
      <h1 class="hero-title">
        <em>{{ section.settings.title_line1 | default: 'Feita à mão,' }}</em><br>
        {{ section.settings.title_line2 | default: 'com alma do Brasil' }}
      </h1>
      <a href="{{ section.settings.cta_url | default: routes.all_products_collection_url }}" class="btn-fill-white">
        {{ section.settings.cta_text | default: 'VER COLEÇÃO' }}
      </a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Imagem"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Imagem de fundo do hero"
    },
    {
      "type": "header",
      "content": "Textos"
    },
    {
      "type": "text",
      "id": "hero_eyebrow",
      "label": "Texto pequeno acima (eyebrow)",
      "default": "ARTE EM MACRAMÊ DO BRASIL"
    },
    {
      "type": "text",
      "id": "title_line1",
      "label": "Título — Linha 1 (itálico)",
      "default": "Feita à mão,"
    },
    {
      "type": "text",
      "id": "title_line2",
      "label": "Título — Linha 2",
      "default": "com alma do Brasil"
    },
    {
      "type": "header",
      "content": "Botão"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Texto do botão",
      "default": "VER COLEÇÃO"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Link do botão"
    }
  ],
  "presets": [
    {
      "name": "Hero"
    }
  ]
}
{% endschema %}
