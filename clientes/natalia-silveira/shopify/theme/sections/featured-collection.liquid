<div class="section-header" id="colecao">
  {%- if section.settings.eyebrow != blank -%}
    <p class="section-eyebrow">{{ section.settings.eyebrow }}</p>
  {%- endif -%}
  <h2 class="section-title">{{ section.settings.title | default: 'PEÇAS MAIS AMADAS' }}</h2>
</div>

{%- assign collection_to_show = collections[section.settings.collection] -%}

<div class="products-section">
  <div class="filter-bar">
    <button class="filter-btn active" data-filter="all">{{ section.settings.filter_all | default: 'TODOS' }}</button>
    <button class="filter-btn" data-filter="conjunto">{{ section.settings.filter_sets | default: 'CONJUNTOS' }}</button>
    <button class="filter-btn" data-filter="vestido">{{ section.settings.filter_dresses | default: 'VESTIDOS' }}</button>
    <button class="filter-btn" data-filter="peca-exclusiva">{{ section.settings.filter_pieces | default: 'PEÇAS EXCLUSIVAS' }}</button>
  </div>

  <div class="product-grid" id="featuredGrid">
    {%- if collection_to_show != blank -%}
      {%- for product in collection_to_show.products limit: section.settings.products_to_show -%}
        {%- render 'product-card', product: product -%}
      {%- endfor -%}
    {%- else -%}
      {%- for product in collections.all.products limit: section.settings.products_to_show -%}
        {%- render 'product-card', product: product -%}
      {%- endfor -%}
    {%- endif -%}
  </div>
</div>

<script>
  (function(){
    var btns = document.querySelectorAll('.filter-btn');
    btns.forEach(function(btn){
      btn.addEventListener('click', function(){
        btns.forEach(function(b){ b.classList.remove('active'); });
        btn.classList.add('active');
        var filter = btn.dataset.filter;
        document.querySelectorAll('#featuredGrid .product-card').forEach(function(card){
          card.style.display = (filter === 'all' || card.dataset.type === filter) ? '' : 'none';
        });
      });
    });
  })();
</script>

{% schema %}
{
  "name": "Grade de Produtos",
  "settings": [
    {
      "type": "header",
      "content": "Cabeçalho"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Texto acima do título",
      "default": "Coleção"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Título da seção",
      "default": "PEÇAS MAIS AMADAS"
    },
    {
      "type": "header",
      "content": "Filtros"
    },
    {
      "type": "text",
      "id": "filter_all",
      "label": "Botão: Todos",
      "default": "TODOS"
    },
    {
      "type": "text",
      "id": "filter_sets",
      "label": "Botão: Conjuntos",
      "default": "CONJUNTOS"
    },
    {
      "type": "text",
      "id": "filter_dresses",
      "label": "Botão: Vestidos",
      "default": "VESTIDOS"
    },
    {
      "type": "text",
      "id": "filter_pieces",
      "label": "Botão: Peças Exclusivas",
      "default": "PEÇAS EXCLUSIVAS"
    },
    {
      "type": "header",
      "content": "Produtos"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Coleção (vazio = todos os produtos)"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 4,
      "max": 28,
      "step": 4,
      "default": 28,
      "label": "Quantidade de produtos"
    }
  ],
  "presets": [
    {
      "name": "Grade de Produtos"
    }
  ]
}
{% endschema %}
