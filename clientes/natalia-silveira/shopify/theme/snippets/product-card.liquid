{%- assign type_tag = '' -%}
{%- for tag in product.tags -%}
  {%- if tag == 'conjunto' or tag == 'vestido' or tag == 'peca-exclusiva' -%}
    {%- assign type_tag = tag -%}
  {%- endif -%}
{%- endfor -%}

{%- assign is_consult = false -%}
{%- if product.tags contains 'consultar-preco' -%}
  {%- assign is_consult = true -%}
{%- endif -%}

<div class="product-card" data-type="{{ type_tag }}" onclick="window.location='{{ product.url }}'">
  <div class="product-card-image">
    {%- if product.featured_image -%}
      <img
        src="{{ product.featured_image | image_url: width: 600 }}"
        alt="{{ product.featured_image.alt | default: product.title }}"
        loading="lazy"
        width="600"
        height="750">
    {%- else -%}
      <div class="product-card-placeholder">
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="m3 9 4-4 4 4 4-4 4 4"/><circle cx="8.5" cy="13.5" r="1.5"/></svg>
      </div>
    {%- endif -%}
    {%- unless product.available -%}
      <span class="sold-out-badge">Esgotado</span>
    {%- endunless -%}
    <div class="product-card-overlay">
      <button class="product-card-btn">Ver Peça</button>
    </div>
  </div>
  <h3 class="product-card-name">{{ product.title }}</h3>
  <p class="product-card-type">{{ product.type }}</p>
  {%- if is_consult -%}
    <p class="product-card-price consult">Sob consulta</p>
  {%- else -%}
    <p class="product-card-price">{{ product.price | money }}</p>
  {%- endif -%}
</div>
